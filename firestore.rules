
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     *
     * Core Philosophy:
     * - User data is private and ownership-based.
     * - Global cache is server-managed only (no client access).
     * - Subscription status, usage ledger and settings are server-written,
     *   but the owner can read their own data.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Study guides (private per user)
    match /users/{userId}/studyGuides/{studyGuideId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId);

      match /textChunks/{textChunkId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwner(userId);
      }
    }

    // Subscription status - owner can read, server writes only
    match /users/{userId}/subscriptionStatus/{docId} {
      allow get, list: if isOwner(userId);
      allow write: if false;
    }

    // Settings (usage policy) - owner can read, server writes only
    match /users/{userId}/settings/{settingId} {
      allow get, list: if isOwner(userId);
      allow write: if false;
    }

    // Usage ledger - owner can read, server writes only
    match /users/{userId}/usageLedger/{ledgerId} {
      allow get, list: if isOwner(userId);
      allow write: if false;
    }

    // Global caches (server/admin only)
    match /explanationCacheEntries/{explanationCacheEntryId} {
      allow get, list, create, update, delete: if false;
    }

    match /canonicalStudyGuides/{canonicalGuideId} {
      allow get, list, create, update, delete: if false;

      match /chunks/{chunkId} {
        allow get, list, create, update, delete: if false;
      }
    }

    // Deny everything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
